// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
  STAFF
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?
  password      String
  role          Role      @default(STUDENT)
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  student       Student?
  announcements Announcement[]
  notifications Notification[]
}

model Student {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId     String    @unique
  course        String
  year          Int
  parentName    String
  parentPhone   String
  parentEmail   String
  address       String
  admissionDate DateTime  @default(now())
  
  roomId        String?
  room          Room?     @relation(fields: [roomId], references: [id])
  
  fees          Fee[]
  payments      Payment[]
  complaints    Complaint[]
  leaveRequests LeaveRequest[]
  visitors      Visitor[]
  eventRSVPs    EventRSVP[]
  messFeedback  MessFeedback[]
  emergencyAlerts EmergencyAlert[]
}

model Building {
  id            String    @id @default(cuid())
  name          String
  address       String
  totalFloors   Int
  floors        Floor[]
}

model Floor {
  id            String    @id @default(cuid())
  floorNumber   Int
  buildingId    String
  building      Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  rooms         Room[]
}

model Room {
  id            String    @id @default(cuid())
  roomNumber    String
  floorId       String
  floor         Floor     @relation(fields: [floorId], references: [id], onDelete: Cascade)
  type          String    // Single, Double, Triple
  capacity      Int
  amenities     String[]  // AC, WiFi, etc.
  status        String    @default("AVAILABLE") // AVAILABLE, FULL, MAINTENANCE
  
  students      Student[]
}

model Fee {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeType       String    // Rent, Mess, Maintenance
  amount        Float
  dueDate       DateTime
  status        String    @default("UNPAID") // PAID, UNPAID, PARTIAL
  academicYear  String
  createdAt     DateTime  @default(now())
  
  payments      Payment[]
}

model Payment {
  id            String    @id @default(cuid())
  feeId         String
  fee           Fee       @relation(fields: [feeId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount        Float
  paymentDate   DateTime  @default(now())
  method        String    // UPI, Card, Net Banking
  transactionId String    @unique
  receiptUrl    String?
}

model Announcement {
  id            String    @id @default(cuid())
  title         String
  content       String    @db.Text
  category      String    // Urgent, General, Event
  priority      String    @default("LOW") // LOW, MEDIUM, HIGH
  targetAudience String   @default("ALL") // ALL, BUILDING_NAME, etc.
  attachments   String[]
  authorId      String
  author        User      @relation(fields: [authorId], references: [id])
  publishedAt   DateTime  @default(now())
  isPinned      Boolean   @default(false)
}

model Complaint {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  category      String    // Electricity, Water, WiFi
  subject       String
  description   String    @db.Text
  photos        String[]
  priority      String    @default("LOW") // LOW, MEDIUM, HIGH
  status        String    @default("PENDING") // PENDING, IN_PROGRESS, RESOLVED, REJECTED
  assignedTo    String?
  resolvedAt    DateTime?
  resolutionNotes String? @db.Text
  createdAt     DateTime  @default(now())
}

model LeaveRequest {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type          String    // Day Out, Overnight, Weekend
  fromDate      DateTime
  toDate        DateTime
  reason        String    @db.Text
  destination   String
  parentApproval Boolean  @default(false)
  wardenApproval String   @default("PENDING") // PENDING, APPROVED, REJECTED
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
}

model Visitor {
  id            String    @id @default(cuid())
  visitorName   String
  phone         String
  purpose       String
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  idProofType   String
  idProofNumber String
  entryTime     DateTime  @default(now())
  exitTime      DateTime?
  photo         String?
}

model Event {
  id            String    @id @default(cuid())
  name          String
  description   String    @db.Text
  banner        String?
  date          DateTime
  location      String
  maxParticipants Int?
  type          String    // Cultural, Sports, Meeting
  createdBy     String
  createdAt     DateTime  @default(now())
  
  rsvps         EventRSVP[]
}

model EventRSVP {
  id            String    @id @default(cuid())
  eventId       String
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status        String    // REGISTERED, ATTENDED, CANCELLED
  createdAt     DateTime  @default(now())
}

model MessMenu {
  id            String    @id @default(cuid())
  dayOfWeek     String    // MONDAY, TUESDAY, etc.
  mealType      String    // BREAKFAST, LUNCH, SNACKS, DINNER
  items         String[]
  weekStartDate DateTime
}

model MessFeedback {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date          DateTime  @default(now())
  rating        Int
  comment       String?   @db.Text
  adminResponse String?   @db.Text
}

model Notification {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  message       String
  type          String    // FEE, COMPLAINT, NOTICE
  isRead        Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

model EmergencyAlert {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type          String    // Medical, Security, Fire
  message       String?   @db.Text
  timestamp     DateTime  @default(now())
  isResolved    Boolean   @default(false)
}
